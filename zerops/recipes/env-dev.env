# Environment: dev — lightweight, single-instance, shared CPU
# Used for feature-branch environments (showcase-dev-*)

# Project
CORE_PACKAGE=

# App service
APP_TYPE=bun@1.2
APP_CORE_MODE=
APP_MIN_CONTAINERS=
APP_MAX_CONTAINERS=
APP_CPU_MODE=
APP_MIN_RAM=0.5
APP_MIN_FREE_RAM=0.25

# Worker service
WORKER_TYPE=python@3.12
WORKER_MIN_CONTAINERS=
WORKER_MAX_CONTAINERS=
WORKER_CPU_MODE=
WORKER_MIN_RAM=0.5
WORKER_MIN_FREE_RAM=

# Database
DB_TYPE=postgresql@17
DB_MODE=NON_HA
DB_CPU_MODE=
DB_MIN_RAM=
DB_MIN_FREE_RAM=

# Redis / Valkey
REDIS_TYPE=valkey@7.2
REDIS_MODE=NON_HA

# Message queue
QUEUE_TYPE=nats@2.12
QUEUE_MODE=NON_HA

# Object storage
STORAGE_SIZE=2
STORAGE_POLICY=public-read
